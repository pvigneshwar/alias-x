# ═══════════════════════════════════════════════════════════════
# ALIAS_X · Environment Configuration
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Primary API Keys ──────────────────────────────────────────
# Google Gemini Vision API (for OCR certificate scanning)
GOOGLE_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY_HERE

# Bland AI Voice Agent API (for automated phone verification)
BLAND_API_KEY=YOUR_BLAND_AI_API_KEY_HERE

# ── SMTP Email Relay ──────────────────────────────────────────
# Gmail recommended: use an App Password, not your main password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# ── Simulation Protocol Block ─────────────────────────────────
# Set USE_TEST_DATA=TRUE to route all uplinks to test endpoints
# instead of the university contacts extracted by OCR.
# CRITICAL: Set to FALSE before live production use.
USE_TEST_DATA=TRUE

# Test endpoints (only used when USE_TEST_DATA=TRUE)
TEST_PHONE_NUMBER=+1234567890
TEST_EMAIL_ADDRESS=test_verification@yourdomain.com
